import random
import re
from dataclasses import dataclass

# ==============================================================================
# Project Tapper - Mobile Extension (Termux / ADB Automation PoC)
#
# 【概要】
# Android実機から取得したUIレイアウトXMLを高速パースし、指定されたボタン
# （resource-id）の領域を特定・抽出する実証スクリプト。
#
# 学内での「睡眠の質と幸福度」に関するウェルネス研究の知見を背景に、
# 機械的な同一座標クリックがシステムや運用に与える歪み（エラー・検知リスク）に着目。
# 抽出した正確な中心座標に対し、ボタンの大きさに応じた人間らしい「微小なゆらぎ」
# を動的に付与するロジック（human_tap_point）を統合しています。
# ==============================================================================


@dataclass
class UIElement:
    """AndroidのUI要素の情報を保持するデータクラス"""

    resource_id: str
    left: int
    top: int
    right: int
    bottom: int

    @property
    def center(self):
        """UI要素の幾何学的な中心座標（真ん中）を計算する"""
        x = (self.left + self.right) // 2
        y = (self.top + self.bottom) // 2
        return x, y

    @property
    def human_tap_point(self):
        """大学でのウェルネス特性研究を応用したロジック。

        ボタンの幅・高さの「10%」を上限として、
        ボタンの領域内（セーフティゾーン）で人間らしいランダムな座標の「ゆらぎ」を生成する。
        """
        x, y = self.center

        # ボタンのサイズ（幅と高さ）を算出
        width = self.right - self.left
        height = self.bottom - self.top

        # 要素が極端に小さい場合を考慮し、最低1ピクセルのマージンを確保しつつ10%のゆらぎ幅を設定
        max_offset_x = max(1, width // 10)
        max_offset_y = max(1, height // 10)

        # 中心座標から計算されたゆらぎ幅の範囲内で、ランダムにズレを発生させる
        human_x = x + random.randint(-max_offset_x, max_offset_x)
        human_y = y + random.randint(-max_offset_y, max_offset_y)

        return human_x, human_y


def extract_elements(xml_text: str, target_resource_id: str):
    """XMLテキストから指定されたresource-idにマッチするUI要素の座標を抽出し、

    UIElementクラスのリストとして返却する関数。
    """
    # resource-idと、それに続くbounds（[左,上][右,下]）の座標を正規表現でキャプチャ
    pattern = (
        rf'resource-id="{re.escape(target_resource_id)}".+?'
        r'bounds="\[([0-9]+),([0-9]+)\]\[([0-9]+),([0-9]+)\]"'
    )

    matches = re.findall(pattern, xml_text, re.DOTALL)

    elements = []
    for left, top, right, bottom in matches:
        elements.append(
            UIElement(
                resource_id=target_resource_id,
                left=int(left),
                top=int(top),
                right=int(right),
                bottom=int(bottom),
            )
        )

    return elements


def main():
    # 本番では ADBコマンド `adb shell uiautomator dump` 等で取得したXMLファイルを指定します
    xml_path = "sample_window_dump.xml"
    target_resource_id = "sample.app:id/target_button"

    try:
        with open(xml_path, "r", encoding="utf-8") as file:
            xml_text = file.read()
    except FileNotFoundError:
        # 初回実行時やテスト用に、ダミーのXMLデータを作成してシミュレート
        print(
            f"[INFO] {xml_path} が見つからないため、検証用テストデータを作成して実行します。"
        )
        xml_text = f'''
        <hierarchy rotation="0">
            <node index="0" class="android.widget.Button" resource-id="{target_resource_id}" bounds="[100,500][300,600]" />
        </hierarchy>
        '''

    # XMLからターゲット要素を抽出
    elements = extract_elements(xml_text, target_resource_id)

    if not elements:
        print("[ERROR] Target UI element was not found.")
        return

    print("==================================================")
    print("UI XML Parsing & Human-Like Tap Simulation")
    print("==================================================")

    for index, element in enumerate(elements, start=1):
        x, y = element.center
        hx, hy = element.human_tap_point

        print(f"[{index}] resource-id: {element.resource_id}")
        print(
            f"    Bounds (領域)    : ({element.left}, {element.top}) - ({element.right}, {element.bottom})"
        )
        print(f"    Absolute Center  : ({x}, {y}) [機械的な中心点]")
        print(
            f"    Human-like Point : ({hx}, {hy}) [心理・認知科学を応用したゆらぎ座標]"
        )
        print(
            f"    Generated Offset : dX: {hx - x}px, dY: {hy - y}px (ボタンサイズに応じた安全な揺らぎ)"
        )
        print("--------------------------------------------------")


if __name__ == "__main__":
    main()